generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// App models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  referralCode  String?   @unique
  referredBy    String?   // referral code used at signup
  accounts      Account[]
  sessions      Session[]
  notes         Note[]
  collections   Collection[]
  aiUsage       AiUsage[]
  plan          UserPlan?
  referrals     Referral[] @relation("ReferrerRelation")
  createdAt     DateTime  @default(now())
}

model Collection {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#7C3AED")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes     Note[]
  createdAt DateTime @default(now())
}

model Note {
  id           String      @id @default(cuid())
  title        String      @default("Untitled")
  content      String      @default("[]")  // JSON string of BlockNote blocks
  tags         String      @default("[]")  // JSON string of string[]
  color        String      @default("#F3E8FF")
  pinned       Boolean     @default(false)
  userId       String
  collectionId String?
  deletedAt    DateTime?
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model AiUsage {
  id        String   @id @default(cuid())
  userId    String
  feature   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model UserPlan {
  userId                 String   @id
  plan                   String   @default("free")
  monthlyLimit           Int      @default(20)
  razorpaySubscriptionId String?
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt              DateTime @updatedAt
}

model Referral {
  id          String    @id @default(cuid())
  referrerId  String
  referredId  String    @unique
  converted   Boolean   @default(false)
  paidOut     Boolean   @default(false)
  reward      Int       @default(100)
  createdAt   DateTime  @default(now())
  convertedAt DateTime?
  referrer    User      @relation("ReferrerRelation", fields: [referrerId], references: [id], onDelete: Cascade)
}
